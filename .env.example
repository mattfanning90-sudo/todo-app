# Required in production. Fail-fast at startup if missing or shorter than 32 chars.
SESSION_SECRET=please-generate-with-openssl-rand-hex-32

# Required in production. Used in digest emails as the absolute URL to the app.
APP_URL=http://localhost:3000

# Postgres
DATABASE_URL=postgres://user:pass@localhost:5432/todo
# Optional: PEM-encoded root CA cert. When set, TLS verification is enabled
# instead of the rejectUnauthorized:false fallback.
DB_CA_CERT=
# Optional: pool sizing — defaults are sensible for a small instance.
PG_POOL_MAX=20

# Optional: separate Postgres for backups. Same DB_CA_CERT pattern applies.
BACKUP_DATABASE_URL=
BACKUP_DB_CA_CERT=
BACKUP_PG_POOL_MAX=4

# Google OAuth (optional — local auth still works without these)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
CALLBACK_URL=http://localhost:3000/auth/google/callback

# SMTP for digest emails (optional)
SMTP_USER=
SMTP_PASS=

# Admin secret for /api/admin/backup and /api/admin/restore (optional)
RESTORE_SECRET=

# Set explicitly in deployment; the app refuses to start in production
# without SESSION_SECRET, APP_URL and DATABASE_URL.
NODE_ENV=development
PORT=3000
