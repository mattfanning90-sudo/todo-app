{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": { "SENTRY_DISABLE_AUTO_UPLOAD": "true" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "mattfanning90@gmail.com",
        "ascAppId": "6774876992",
        "appleTeamId": "KGQVBM3UF4"
      }
    }
  }
}
