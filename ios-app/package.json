{
  "name": "todo-app-ios",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "test:ci": "jest --forceExit --runInBand",
    "test:watch": "jest --watch",
    "generate-icon": "node scripts/generate-icon.mjs"
  },
  "jest": {
    "preset": "jest-expo",
    "maxWorkers": 2,
    "testTimeout": 15000,
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-gesture-handler|react-native-reanimated|react-native-safe-area-context|react-native-screens|react-native-draggable-flatlist)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@ungap/structured-clone": "^1.3.1",
    "expo": "^55.0.0",
    "expo-auth-session": "~55.0.16",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-haptics": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "jest-expo": "~54.0.17",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-dnd": "^2.0.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.18",
    "jest-fetch-mock": "^3.0.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
