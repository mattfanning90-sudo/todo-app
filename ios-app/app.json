{
  "expo": {
    "name": "Todo",
    "slug": "todo-app",
    "scheme": "todoapp",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matthewfanning.todo",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.715885239899-a245f5lnvhg9akc82secj3u7l20nfui6"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.todoapp.android",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "apiBase": "https://todo-app-production-a338.up.railway.app",
      "eas": {
        "projectId": "8cc288c3-7847-47a2-a1fe-55059996080b"
      }
    },
    "owner": "mfanning90"
  }
}
